<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/customWindowBackground"
    android:scrollbars="none">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingBottom="24dp">

        <!-- Header -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/settings_title"
            style="@style/AppTitleLarge"
            android:textColor="?attr/customTextPrimary"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp"/>

        <!-- Appearance -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/label_appearance"
            style="@style/AppTitleMedium"
            android:textColor="?attr/customTextPrimary"
            android:paddingHorizontal="24dp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            app:cardCornerRadius="24dp" app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/customCardBackground"
            app:strokeColor="?attr/customBorderColor"
            app:strokeWidth="1dp">

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/grid_themes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                app:columnCount="3"
                app:alignmentMode="alignMargins"
                app:useDefaultMargins="false"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Preferences Section -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/label_preferences"
            style="@style/AppTitleMedium"
            android:textColor="?attr/customTextPrimary"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            app:cardCornerRadius="24dp" app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/customCardBackground"
            app:strokeColor="?attr/customBorderColor"
            app:strokeWidth="1dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="8dp">

                <!-- Notifications -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="64dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/label_push_notifications"
                        android:textColor="?attr/customTextPrimary" android:textSize="15sp"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_notifs"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:checked="true"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/customBorderColor" android:layout_marginHorizontal="16dp"
                    android:alpha="0.5"/>

                <!-- Reminders Row -->
                <LinearLayout android:id="@+id/row_reminders"
                    android:layout_width="match_parent" android:layout_height="64dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp" android:clickable="true" android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/label_daily_reminders"
                        android:textColor="?attr/customTextPrimary" android:textSize="15sp"/>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right" app:tint="?attr/customTextSecondary"
                        android:alpha="0.5"
                        android:contentDescription="@string/label_daily_reminders"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/customBorderColor" android:layout_marginHorizontal="16dp"
                    android:alpha="0.5"/>

                <!-- Rate Row -->
                <LinearLayout android:id="@+id/row_rate"
                    android:layout_width="match_parent" android:layout_height="64dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp" android:clickable="true" android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/label_rate_app"
                        android:textColor="?attr/customTextPrimary" android:textSize="15sp"/>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right" app:tint="?attr/customTextSecondary"
                        android:alpha="0.5"
                        android:contentDescription="@string/label_rate_app"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="?attr/customBorderColor" android:layout_marginHorizontal="16dp"
                    android:alpha="0.5"/>

                <!-- Share Row -->
                <LinearLayout android:id="@+id/row_share"
                    android:layout_width="match_parent" android:layout_height="64dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:paddingHorizontal="16dp" android:clickable="true" android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/label_share_friends"
                        android:textColor="?attr/customTextPrimary" android:textSize="15sp"/>
                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_right" app:tint="?attr/customTextSecondary"
                        android:alpha="0.5"
                        android:contentDescription="@string/label_share_friends"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Danger Zone -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_connect_google"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="48dp"
            android:text="@string/btn_connect_google"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:visibility="gone"
            app:icon="@drawable/ic_google_logo"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/row_logout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:text="@string/btn_sign_out"
            android:textColor="@color/error_red"
            android:textAllCaps="false"
            android:textStyle="bold"
            style="@style/Widget.Material3.Button.TextButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete_account"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="4dp"
            android:text="Delete Account"
            android:textColor="@color/error_red"
            android:textAllCaps="false"
            android:textStyle="bold"
            style="@style/Widget.Material3.Button.TextButton"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Version 1.0.0"
            android:textColor="?attr/customTextSecondary" android:textSize="12sp"
            android:gravity="center" android:layout_marginTop="24dp" android:alpha="0.5"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
