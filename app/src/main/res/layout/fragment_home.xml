<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/customWindowBackground">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── HEADER ────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning,"
                        android:textColor="?attr/customTextSecondary"
                        android:textSize="14sp"
                        android:letterSpacing="0.02"/>

                    <TextView android:id="@+id/tv_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alex 👋"
                        style="@style/AppTitleLarge"
                        android:textColor="?attr/customTextPrimary"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <!-- Streak badge -->
                <LinearLayout android:id="@+id/ll_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_streak_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="14sp"/>
                    <TextView android:id="@+id/tv_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7"
                        android:textColor="@color/streak_fire"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── PROGRESS CARD ──────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/customCardBackground"
                app:strokeColor="?attr/customBorderColor"
                app:strokeWidth="1dp">

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/label_progress"
                            android:textColor="?attr/customTextSecondary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"/>
                        <TextView android:id="@+id/tv_progress_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4 / 6"
                            android:textColor="@color/primary_blue"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <ProgressBar android:id="@+id/pb_today"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="16dp"
                        android:progressDrawable="@drawable/progress_bar_gradient"
                        android:max="100"
                        android:progress="66"/>

                    <TextView android:id="@+id/tv_progress_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Keep going, you're almost there!"
                        android:textColor="?attr/customTextSecondary"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp"
                        android:alpha="0.8"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── QUOTE / SPARK ───────────────────────────── -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp">

                <LinearLayout android:id="@+id/quote_card_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_quote_card"
                    android:padding="20dp"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView android:id="@+id/tv_quote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/customTextPrimary"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        android:text="Success is the sum of small efforts, repeated day in and day out."/>

                    <TextView android:id="@+id/tv_quote_author"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/customTextSecondary"
                        android:textSize="11sp"
                        android:layout_marginTop="8dp"
                        android:text="— Robert Collier"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ── SECTION: HABITS ─────────────────────────── -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <TextView android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/label_your_habits"
                    style="@style/AppTitleMedium"
                    android:textColor="?attr/customTextPrimary"/>

                <TextView android:id="@+id/btn_rest_day"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_rest_day"
                    android:textColor="@color/primary_blue"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:background="@drawable/bg_chip_outline"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- ── HABITS LIST ─────────────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_habits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                android:paddingBottom="24dp"/>

            <!-- ── EMPTY STATE ─────────────────────────────── -->
            <LinearLayout android:id="@+id/ll_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="80dp"
                android:visibility="gone">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌱"
                    android:textSize="64sp"/>
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_title"
                    style="@style/AppTitleMedium"
                    android:textColor="?attr/customTextPrimary"
                    android:layout_marginTop="20dp"/>
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_subtitle"
                    android:textColor="?attr/customTextSecondary"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>