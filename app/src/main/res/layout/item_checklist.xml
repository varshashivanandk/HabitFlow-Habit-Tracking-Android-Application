<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minHeight="48dp"
    android:paddingVertical="4dp">

    <CheckBox
        android:id="@+id/checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="?attr/colorPrimary"/>

    <EditText
        android:id="@+id/et_checklist_title"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:hint="@string/subtask_hint"
        android:textSize="14sp"
        android:background="@null"
        android:padding="8dp"
        android:textColor="?attr/customTextPrimary"
        android:inputType="textCapSentences"/>

    <ImageButton
        android:id="@+id/btn_remove"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_close"
        android:contentDescription="@string/content_description_remove_task"
        android:alpha="0.65"
        app:tint="?attr/customTextSecondary"/>
</LinearLayout>
